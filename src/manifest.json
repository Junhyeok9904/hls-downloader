{
    "manifest_version": 3,
    "name": "Authorized HLS Media Downloader",
    "version": "0.1.0",
    "description": "Download authorized HLS media streams.",
    "permissions": [
        "storage",
        "declarativeNetRequest"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    }
}
